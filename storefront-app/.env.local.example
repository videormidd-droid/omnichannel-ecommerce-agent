# Supabase (super database) — উভয় অ্যাপে একই ভ্যালু ব্যবহার হবে
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # শুধু server-side, .gitignore এ রাখুন

# SMS provider (BulkSMSBD / Alpha SMS ইত্যাদি দিয়ে বদলান)
SMS_API_URL=https://your-sms-provider.com/api/send
SMS_API_KEY=your_sms_api_key
