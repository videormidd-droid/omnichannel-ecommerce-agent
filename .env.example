# ============================================================
#  Copy this file to ".env" and fill in real values.
#  NEVER commit .env to git. NEVER paste these values in chat.
#  Tip: configure ONE or BOTH channels. A channel with no
#  credentials is simply skipped at startup.
# ============================================================

PORT=3000

# ---- Meta WhatsApp Cloud API ----
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Use a PERMANENT System User token for 24/7 (NOT the 24h temporary token)
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token
# A secret string YOU invent; put the SAME value in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=make_this_a_long_random_secret_123456
WHATSAPP_API_VERSION=v21.0
META_APP_SECRET=your_app_secret

# ---- Telegram Bot API ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# A secret string YOU invent; Telegram echoes it back in a header so you can verify requests
TELEGRAM_WEBHOOK_SECRET=make_this_another_long_random_secret
# Public HTTPS base URL of THIS server (used by: npm run set-telegram-webhook)
PUBLIC_BASE_URL=https://your-public-url

# ---- Supabase (PostgreSQL) ----
SUPABASE_URL=https://your-project-ref.supabase.co
# SERVICE ROLE key (server-side only, bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- AI brain: choose provider "gemini" (free tier, easy) or "anthropic" ----
AI_PROVIDER=gemini
# Google Gemini — get a FREE key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
# Anthropic Claude — only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
AI_MODEL=claude-3-5-sonnet-latest
# (Leave the chosen provider's key as placeholder to run in echo/TEST mode)

# ---- Business ----
STORE_NAME=Your Store Name
SUPPORT_HANDOFF_CONTACT=8801XXXXXXXXX
